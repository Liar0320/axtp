{
  "name": "@axtp/generator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "axtp-gen": "./dist/cli.js"
  },
  "scripts": {
    "axtp-gen": "node dist/cli.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "validate": "node dist/cli.js validate --spec ..",
    "generate": "node dist/cli.js generate --spec .. --out ../runtimes/cpp-core/include/axtp/generated --out-docs ../docs/generated --out-mcp ../tooling/mcp --out-vectors ../tooling/test-vectors",
    "validate:protocol": "node dist/cli.js validate-protocol --spec ..",
    "generate:protocol": "node dist/cli.js generate-protocol --spec .. --out ../docs/generated"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@11.3.0"
}
