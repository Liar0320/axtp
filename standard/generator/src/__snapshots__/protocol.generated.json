      "production": true
    },
    {
      "name": "AXTP-WS-TEXT",
      "family": "websocket",
      "frameProfile": "none",
      "production": false,
      "usage": "debug-or-legacy-adapter"
    },
    {
      "name": "AXTP-HTTP-JSON",
      "family": "http",
      "frameProfile": "none",
      "production": false,
      "usage": "debug-or-legacy-adapter"
    }
  ],
  "payloadTypes": [
    {
      "name": "CONTROL",
      "id": 1,
      "headerBytes": 5,
      "description": "Logical session control payload."
    },
    {
      "name": "RPC",
      "id": 2,
      "headerBytes": 11,
      "description": "Binary request, response, event and error payload."
    },
    {
      "name": "STREAM",
      "id": 3,
      "headerBytes": 16,
      "description": "Chunk-oriented data plane payload."
    }
  ],
  "control": {
    "requiredOpcodes": [
      "OPEN",
      "ACCEPT"
    ],
    "optionalOpcodes": [
      "READY"
    ],
    "reservedOpcodes": [
      "NACK",
      "RESUME"
    ],
    "rules": [
      "v1 Core requires OPEN and ACCEPT before RPC or STREAM payloads.",
      "READY is not required by v1 Core and must not be assumed by peers.",
      "Dynamic header negotiation is not performed in v1."
    ]
  },
  "stream": {
    "header": {
      "name": "AxtpStreamHeader",
      "size": 16,
      "fields": [
        {
          "name": "streamId",
          "type": "uint32"
        },
        {
          "name": "seq",
          "type": "uint32"
        },
        {
          "name": "position",
          "type": "uint32"
        },
        {
          "name": "chunkLength",
          "type": "uint16"
        },
        {
          "name": "flags",
          "type": "uint16"
        }
      ]
    },
    "rules": [
      "STREAM uses the unified 16-byte header in production transports.",
      "The historical 8-byte stream header is not part of AXTP v1 Core.",
      "WebSocket Text and HTTP JSON must not carry production STREAM data."
    ]
  },
  "compatibility": {
    "legacySources": [
      "protocol-source/legacy-docs/02-registry/"
    ],
    "rules": [
      "Stable methodId, eventId and error code values must not be reused.",
      "Legacy command mappings may be preserved as metadata under methods[].legacy.",
      "WebSocket Text and HTTP JSON may exist only as debug or legacy adapter paths."
    ]
  },
